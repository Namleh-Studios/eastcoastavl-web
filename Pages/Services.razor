@page "/services"

<PageTitle>Services | Eastcoast AVL</PageTitle>

<section class="hero-bg pt-32 pb-24" style="position:relative;">
    <div class="max-w-7xl mx-auto px-6 hero-content">
        <p class="section-label mb-4">What We Offer</p>
        <h1 class="font-display font-black text-white leading-tight mb-6"
            style="font-size:clamp(2.5rem,6vw,5rem);">
            Professional<br />
            <span class="text-blue">Services</span>
        </h1>
        <p class="text-white-60 text-xl max-w-2xl leading-relaxed">
            Audio, video, stage lighting, IT, and security solutions for churches,
            schools, homes, and businesses — installs, sales, training, and support.
        </p>
    </div>
    <div class="wave-bottom">
        <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 80L1440 80L1440 40C1200 80 960 0 720 40C480 80 240 0 0 40L0 80Z" />
        </svg>
    </div>
</section>

<section class="py-24 bg-primary">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md-grid-2 lg-grid-3 gap-8">
            @foreach (var svc in _services)
            {
                <div class="card p-8">
                    <div class="icon-box mb-5">
                        <Icon Name="@svc.Icon" Size="28" />
                    </div>
                    <h3 class="font-display font-bold text-xl mb-3 text-primary">@svc.Title</h3>
                    <p class="text-secondary text-sm leading-relaxed">@svc.Description</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-16 bg-navy-900">
    <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="font-display font-black text-white mb-5"
            style="font-size:clamp(1.8rem,3vw,2.5rem);">
            Ready to Get Started?
        </h2>
        <p class="text-white-60 mb-8">Let's talk about how Eastcoast AVL can help with your next project.</p>
        <div class="flex flex-wrap items-center justify-center gap-4">
            <a href="/contact" class="btn-primary">Get A Quote <Icon Name="arrow-right" Size="16" /></a>
        </div>
    </div>
</section>

@code {
    private record Service(string Icon, string Title, string Description);

    private static readonly Service[] _services =
    [
        new("mic", "Audio Systems", "Live sound production, system design, speaker installation, and mixing for churches, schools, events, and commercial spaces."),
        new("video", "Video Production", "Multi-camera production, streaming, IMAG, broadcast video, and display system integration for any venue."),
        new("lightbulb", "Stage Lighting", "Lighting design, programming, installation, and operation for worship, theatrical productions, and live events."),
        new("shield", "Security Cameras", "Security camera system design, installation, and monitoring for homes, businesses, churches, and schools."),
        new("wifi", "IT Setup & Support", "Network design, infrastructure setup, troubleshooting, and ongoing IT support for homes and businesses."),
        new("settings", "System Installation", "Full AVL and technology system design and installation — from consoles and speakers to cameras and network infrastructure."),
        new("shopping-bag", "Sales & Equipment", "Equipment sourcing, sales, and procurement — we help you get the right gear at the right price."),
        new("graduation-cap", "Training", "Hands-on training for your team on audio, video, lighting, IT systems, and security equipment operation."),
        new("users", "Consulting", "Expert consulting on system design, technology planning, and production workflows for any environment."),
        new("calendar", "Production Operation", "Full production operation and technical direction for live events, conferences, and worship services."),
    ];
}
