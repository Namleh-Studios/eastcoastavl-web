@page "/about"

<PageTitle>About | Eastcoast AVL</PageTitle>

<section class="hero-bg pt-32 pb-24" style="position:relative;">
    <div class="max-w-7xl mx-auto px-6 hero-content">
        <p class="section-label mb-4">About Us</p>
        <h1 class="font-display font-black text-white leading-tight mb-6"
            style="font-size:clamp(2.5rem,6vw,5rem);">
            Built by People<br />
            <span class="text-blue">Who Do This.</span>
        </h1>
        <p class="text-white-60 text-xl max-w-2xl leading-relaxed">
            Eastcoast AVL was founded by working audio, video, and lighting professionals
            with years of hands-on experience in church production and live events.
        </p>
    </div>
    <div class="wave-bottom">
        <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 80L1440 80L1440 40C1200 80 960 0 720 40C480 80 240 0 0 40L0 80Z" />
        </svg>
    </div>
</section>

<section class="py-24 bg-primary">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md-grid-2 gap-16 items-center">
            <div>
                <p class="section-label mb-3">Our Story</p>
                <h2 class="section-title mb-6">We Know What It Takes</h2>
                <div style="display:flex;flex-direction:column;gap:1rem;" class="text-secondary leading-relaxed">
                    <p>
                        Eastcoast AVL started with a simple belief: churches and live events deserve
                        the same quality of technical production that major touring acts and broadcast
                        networks expect — without the agency overhead.
                    </p>
                    <p>
                        We're based in Jacksonville, NC, and we've spent years behind the console,
                        on the lighting rig, and behind the camera for Sunday services, conferences,
                        and large-scale events up and down the East Coast.
                    </p>
                    <p>
                        Every project we take on is personal — we treat your venue, your service,
                        and your event like it's our own. That's the Eastcoast difference.
                    </p>
                </div>
            </div>
            <div class="stats-box">
                <div class="grid grid-cols-2 gap-8">
                    @foreach (var stat in _stats)
                    {
                        <div>
                            <p class="stat-value">@stat.Value</p>
                            <p class="text-white-50 text-sm">@stat.Label</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-16 bg-secondary">
    <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="section-title mb-5">Want to Work With Us?</h2>
        <a href="/contact" class="btn-primary">
            Get In Touch <Icon Name="arrow-right" Size="16" />
        </a>
    </div>
</section>

@code {
    private record Stat(string Value, string Label);

    private static readonly Stat[] _stats =
    [
        new("100+", "Events Produced"),
        new("50+", "Church Clients"),
        new("8+", "Years Experience"),
        new("24/7", "Support Available"),
    ];
}
